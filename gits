#!/usr/bin/env bash
set -e

if [ -z "$1" ]; then
    echo "用法: gits <github-tree-url> [目标目录]"
    echo "示例: gits https://github.com/BlackArch/blackarch-artwork/tree/master/wallpaper"
    echo "      gits https://github.com/BlackArch/blackarch-artwork/tree/master/wallpaper ~/Downloads"
    exit 1
fi

URL="$1"
TARGET_DIR="${2:-.}"
# 把目标目录转成绝对路径，避免 cd 后路径失效
TARGET_DIR=$(realpath "$TARGET_DIR")
REPO_URL=""
BRANCH=""
FOLDER_PATH=""

# Parse URL: https://github.com/<owner>/<repo>/tree/<branch>/<path>
if [[ "$URL" =~ ^https://github\.com/([^/]+)/([^/]+)/tree/([^/]+)/(.+)$ ]]; then
    OWNER="${BASH_REMATCH[1]}"
    REPO="${BASH_REMATCH[2]}"
    BRANCH="${BASH_REMATCH[3]}"
    FOLDER_PATH="${BASH_REMATCH[4]}"
    REPO_URL="https://github.com/${OWNER}/${REPO}.git"
else
    echo "错误: URL 格式不正确，请确保是 GitHub 的 tree 链接"
    exit 1
fi

FOLDER_NAME=$(basename "$FOLDER_PATH")
TMP_DIR=$(mktemp -d)

echo "正在克隆仓库元数据..."
git clone --filter=blob:none --no-checkout --single-branch --branch "$BRANCH" "$REPO_URL" "$TMP_DIR" 2>/dev/null

cd "$TMP_DIR"

echo "正在设置稀疏检出: $FOLDER_PATH"
git sparse-checkout init --cone
git sparse-checkout set "$FOLDER_PATH"
git checkout "$BRANCH"

echo "正在提取文件夹到: $TARGET_DIR"
mkdir -p "$TARGET_DIR"
cp -r "$FOLDER_PATH" "$TARGET_DIR/"

cd ..
rm -rf "$TMP_DIR"

echo "完成! 文件夹已下载到: $TARGET_DIR/$FOLDER_NAME"
